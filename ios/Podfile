# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = ''

      # permission_handler requires
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CONTACTS=1',
        'PERMISSION_NOTIFICATIONS=1',
      ]
    end
  end

  # Patch flutter_contacts crash: rootViewController is nil at registration time
  # See: https://github.com/QuisApp/flutter_contacts/issues/171
  plugin_swift = File.join(
    installer.sandbox.root.parent, '.symlinks', 'plugins',
    'flutter_contacts', 'ios', 'Classes', 'SwiftFlutterContactsPlugin.swift'
  )
  if File.exist?(plugin_swift)
    content = File.read(plugin_swift)
    crash_line = 'let rootViewController = UIApplication.shared.delegate!.window!!.rootViewController!'
    if content.include?(crash_line)
      patched = content.gsub(
        crash_line,
        <<~'SWIFT'.chomp
        // Patched: safely unwrap rootViewController to prevent crash on app startup
                guard let delegate = UIApplication.shared.delegate,
                      let window = delegate.window ?? nil,
                      let rootViewController = window.rootViewController else {
                    let fallbackInstance = SwiftFlutterContactsPlugin(UIViewController())
                    registrar.addMethodCallDelegate(fallbackInstance, channel: channel)
                    eventChannel.setStreamHandler(fallbackInstance)
                    return
                }
        SWIFT
      )
      File.write(plugin_swift, patched)
      Pod::UI.puts "Patched flutter_contacts rootViewController crash"
    end
  end
end
